# 微信登录配置
# 获取方式：https://open.weixin.qq.com/
NEXT_PUBLIC_WECHAT_APPID=wx1234567890abcdef
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# QQ 登录配置
# 获取方式：https://connect.qq.com/
NEXT_PUBLIC_QQ_APP_ID=123456789
QQ_APP_SECRET=your_qq_app_secret
QQ_REDIRECT_URI=http://localhost:3000/api/auth/qq/callback

